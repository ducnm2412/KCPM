            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const isCollectionRun = String(pm.environment.get('isCollectionRun')).trim().toLowerCase() === 'true';",
                  "const testCase = pm.iterationData.get('test_case') || 'register';",
                  "let json = {};",
                  "let isBug = false;",
                  "let bugReason = '';",
                  "try { json = pm.response.json(); } catch (e) { isBug = true; bugReason += '\\n- Response is not JSON'; }",
                  "const responseData = json.data || json;",
                  "if (responseData.accessToken) pm.environment.set('accessToken', responseData.accessToken);",
                  "if (responseData.refreshToken) pm.environment.set('refreshToken', responseData.refreshToken);",
                  "if (responseData.userId) pm.environment.set('userId', responseData.userId);",
                  "const expectedStatus = pm.iterationData.get('expected_status');",
                  "const expectedSuccess = pm.iterationData.get('expected_success');",
                  "const expectedMessage = pm.iterationData.get('expected_message');",
                  "const expectedSuccessBool = String(expectedSuccess).trim().toLowerCase() === 'true';",
                  "const rawRequestBody = pm.request.body && pm.request.body.raw ? pm.request.body.raw : 'No request body';",
                  "const resolvedRequestBody = pm.variables.replaceIn(rawRequestBody);",
                  "console.log('===== REGISTER TEST DETAIL =====');",
                  "console.log('Test case:', testCase);",
                  "console.log('Request Body:', resolvedRequestBody);",
                  "console.log('Expected Result:', JSON.stringify({ statusCode: Number(expectedStatus), success: expectedSuccessBool, message: expectedMessage }, null, 2));",
                  "console.log('Actual Result:', JSON.stringify({ statusCode: pm.response.code, success: json.success, message: json.message, responseBody: json }, null, 2));",
                  "console.log('================================');",
                  "if (expectedStatus !== undefined) {",
                  "  pm.test('[' + testCase + '] status code dung', function () { pm.expect(pm.response.code).to.eql(Number(expectedStatus)); });",
                  "  if (pm.response.code !== Number(expectedStatus)) { isBug = true; bugReason += '\\n- Expected status: ' + expectedStatus + ', Actual status: ' + pm.response.code; }",
                  "} else {",
                  "  pm.test('Register returns success response', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "}",
                  "if (expectedSuccess !== undefined) {",
                  "  pm.test('[' + testCase + '] success dung', function () { pm.expect(json.success).to.eql(expectedSuccessBool); });",
                  "  if (json.success !== expectedSuccessBool) { isBug = true; bugReason += '\\n- Expected success: ' + expectedSuccessBool + ', Actual success: ' + json.success; }",
                  "}",
                  "if (expectedMessage !== undefined) {",
                  "  pm.test('[' + testCase + '] message dung', function () { pm.expect(json.message).to.eql(expectedMessage); });",
                  "  if (json.message !== expectedMessage) { isBug = true; bugReason += '\\n- Expected message: ' + expectedMessage + ', Actual message: ' + json.message; }",
                  "}",
                  "if (!isCollectionRun || !isBug) {",
                  "  console.log(!isCollectionRun ? 'Manual send or Jira disabled' : 'Test passed - no Jira issue created');",
                  "  return;",
                  "}",
                  "const jiraDomain = pm.environment.get('jiraDomain');",
                  "const jiraEmail = pm.environment.get('jiraEmail');",
                  "const jiraToken = pm.environment.get('jiraToken');",
                  "const jiraProjectKey = pm.environment.get('jiraProjectKey');",
                  "if (!jiraDomain || !jiraEmail || !jiraToken || !jiraProjectKey) {",
                  "  console.log('Missing Jira environment variables - skip issue creation');",
                  "  return;",
                  "}",
                  "const location = pm.execution.location || [];",
                  "const folderName = location.length >= 2 ? location[1] : 'Auth';",
                  "const descriptionText = 'Folder: ' + folderName + '\\n\\nRequest: ' + pm.info.requestName + '\\n\\nTest case: ' + testCase + '\\n\\nMethod: ' + pm.request.method + '\\n\\nEndpoint:\\n' + pm.request.url + '\\n\\n-----------------------------------\\n\\nRequest Body:\\n' + resolvedRequestBody + '\\n\\n-----------------------------------\\n\\nExpected Result:\\nStatus Code: ' + expectedStatus + '\\nSuccess: ' + expectedSuccessBool + '\\nMessage: ' + expectedMessage + '\\n\\n-----------------------------------\\n\\nActual Result:\\nStatus Code: ' + pm.response.code + '\\nSuccess: ' + json.success + '\\nMessage: ' + json.message + '\\n\\nResponse Body:\\n' + pm.response.text() + '\\n\\n-----------------------------------\\n\\nBug Reason:' + bugReason + '\\n\\nDetected automatically from Postman/Newman.';",
                  "pm.sendRequest({",
                  "  url: 'https://' + jiraDomain + '/rest/api/3/issue',",
                  "  method: 'POST',",
                  "  header: {",
                  "    'Content-Type': 'application/json',",
                  "    'Accept': 'application/json',",
                  "    'Authorization': 'Basic ' + btoa(jiraEmail + ':' + jiraToken)",
                  "  },",
                  "  body: {",
                  "    mode: 'raw',",
                  "    raw: JSON.stringify({",
                  "      fields: {",
                  "        project: { key: jiraProjectKey },",
                  "        summary: '[' + folderName + '] ' + pm.info.requestName + ' failed - ' + testCase,",
                  "        description: { type: 'doc', version: 1, content: [{ type: 'paragraph', content: [{ type: 'text', text: descriptionText }] }] },",
                  "        issuetype: { name: 'Task' }",
                  "      }",
                  "    })",
                  "  }",
                  "}, function (err, res) {",
