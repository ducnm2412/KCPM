[
  {
    "test_case": "login_success",
    "email": "admin@uth.edu.vn",
    "password": "admin123",
    "expected_status": 200,
    "expected_success": true,
    "expected_message": "Success"
  },
  {
    "test_case": "email_not_found",
    "email": "notfound@uth.edu.vn",
    "password": "admin123",
    "expected_status": 401,
    "expected_success": false,
    "expected_message": "Invalid email or password"
  },
  {
    "test_case": "missing_email",
    "email": "",
    "password": "admin123",
    "expected_status": 400,
    "expected_success": false,
    "expected_message": "Validation failed"
  },
  {
    "test_case": "missing_password",
    "email": "admin@uth.edu.vn",
    "password": "",
    "expected_status": 400,
    "expected_success": false,
    "expected_message": "Validation failed"
  },
  {
    "test_case": "invalid_email_format",
    "email": "abcxyz",
    "password": "Password123",
    "expected_status": 400,
    "expected_success": false,
    "expected_message": "Validation failed"
  }
]
